# 服务配置
PORT=4000
FRONTEND_URL=http://localhost:5173

# Spotify API（可选，无 Key 时使用本地音乐）
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# TTS 语音合成
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY= # Gemini API
COSYVOICE_API_URL=http://localhost:50000 # CosyVoice 本地部署（需要 GPU）
DEFAULT_TTS_PROVIDER=edge # 🔥 推荐！Edge TTS 完全免费，粤语质量超棒
DEFAULT_TTS_VOICE=alloy # Edge 粤语语音: alloy(婉龙), nova(晓佳), shimmer(晓曼)

# 其他 API
WEATHER_API_KEY= # 可选，用于天气相关的旁白文案

# 本地音乐
LOCAL_MUSIC_PATH=/path/to/your/music/folder
PREFERRED_MUSIC_SOURCE=local # local / spotify
